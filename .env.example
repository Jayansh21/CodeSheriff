# CodeSheriff Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Required — Get free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Required for GitHub App webhook authentication
GITHUB_APP_ID=your_github_app_id_here

# Required — paste full contents of your .pem file on one line
GITHUB_PRIVATE_KEY=your_github_private_key_here

# Required — random string you set when creating the GitHub App
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional — HuggingFace token for pushing/pulling private models
HF_TOKEN=your_huggingface_token_here

# Model source — set to HuggingFace repo path after pushing model
# Local example:  models/codesheriff-model/final
# Remote example: your-username/codesheriff-bug-classifier
MODEL_PATH=models/codesheriff-model/final

# Logging level: DEBUG for development, INFO for production
LOG_LEVEL=INFO

# Set to 'true' to load the model locally (requires torch + ~2GB RAM)
# Leave unset or 'false' for production (uses HuggingFace Space inference)
USE_LOCAL_MODEL=false

# HuggingFace Space that serves the model (used when USE_LOCAL_MODEL=false)
INFERENCE_SPACE_ID=jayansh21/codesheriff-inference
